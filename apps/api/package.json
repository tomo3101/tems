{
  "name": "api",
  "version": "1.0.3",
  "private": true,
  "type": "module",
  "exports": {
    "./hc": {
      "import": {
        "import": "./dist/src/hc.js",
        "types": "./dist/src/hc.d.ts"
      }
    },
    "./schema/*": {
      "import": {
        "import": "./dist/src/application/schemas/*.js",
        "types": "./dist/src/application/schemas/*.d.ts"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint \"src/**/*.ts*\" --max-warnings 0",
    "start": "node ./dist/src/index.js",
    "push": "drizzle-kit push",
    "remove-dist": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.20",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.12.9",
    "mysql2": "^3.20.0",
    "react": "^19.2.4",
    "resend": "^4.8.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^0.19.10",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "drizzle-kit": "^0.30.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "zod": "^3.25.76"
  }
}
